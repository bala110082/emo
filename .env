
# UPLOAD_FOLDER=static/uploads
# GENERATED_FOLDER=static/generated
# TEMP_FOLDER=static/temp
# MAX_CONTENT_LENGTH=16777216  # 16MB in bytes


# # Google Gemini API (for BGM Generation)
# GOOGLE_API_KEY=your_google_gemini_api_key_here




# # Video Processing Settings
# VIDEO_FPS=1  # Frames per second to analyze
# MAX_VIDEO_DURATION=300  # Maximum video duration in seconds (5 minutes)

# # Music Generation Settings
# DEFAULT_BGM_DURATION=30  # Default BGM duration in seconds
# DEFAULT_BPM=120
# DEFAULT_TEMPERATURE=1.0

# # Logging Configuration
# LOG_LEVEL=INFO
# LOG_FILE=logs/emorhythm.log

# # Session Configuration
# SESSION_TYPE=filesystem
# PERMANENT_SESSION_LIFETIME=3600  # 1 hour in seconds

# # Security Settings
# ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,mp4,avi,mov,mkv,webm